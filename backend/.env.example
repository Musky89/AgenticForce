DATABASE_URL=sqlite+aiosqlite:///./agenticforce.db
OPENAI_API_KEY=sk-your-key-here
FAL_KEY=your-fal-ai-key-here
GEMINI_API_KEY=your-gemini-api-key-here
SECRET_KEY=change-this-to-a-random-secret

# Default image provider: "flux" (LoRA support) or "imagen" (raw quality)
# Auto-selects Flux when a client LoRA is available, regardless of this setting
DEFAULT_IMAGE_PROVIDER=imagen
